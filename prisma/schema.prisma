generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  STAFF
  DOCTOR
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  RESCHEDULED
  COMPLETED
  NO_SHOW
}

enum AppointmentSource {
  ADMIN
  PUBLIC_BOOKING
  WHATSAPP
  IMPORT
}

enum TokenType {
  CONFIRM
  CANCEL
  RESCHEDULE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum WaitlistStatus {
  ACTIVE
  OFFERED
  CONVERTED
  CANCELLED
  EXPIRED
}

enum WaitlistOfferStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum WhatsAppConversationStatus {
  ACTIVE
  NEEDS_HUMAN
  CLOSED
}

enum WhatsAppIntent {
  AGENDAR_CITA
  CONFIRMAR_CITA
  CANCELAR_CITA
  REAGENDAR_CITA
  VER_CITA
  HABLAR_CON_PERSONA
  VER_AGENDA_HOY
  VER_AGENDA_MANANA
  CREAR_CITA
  BLOQUEAR_HORARIO
  RESUMEN_DIA
}

enum WhatsAppMessageDirection {
  INBOUND
  OUTBOUND
}

enum WhatsAppMessageType {
  TEXT
  INTERACTIVE
  TEMPLATE
  SYSTEM
}

enum WhatsAppMessageStatus {
  RECEIVED
  PROCESSED
  SENT
  FAILED
}

enum WhatsAppBookingDraftStatus {
  COLLECTING_SERVICE
  COLLECTING_DOCTOR
  COLLECTING_TIME
  COLLECTING_PATIENT
  READY_TO_CONFIRM
  CONFIRMED
  CANCELLED
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  passwordHash        String
  phoneE164           String?
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  clinicMemberships   ClinicMember[]
  doctorProfiles      Doctor[]             @relation("DoctorLinkedUser")
  auditLogs           AuditLog[]
  sessions            Session[]
  whatsAppCommandLogs WhatsAppCommandLog[]

  @@index([isActive])
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt, revokedAt])
}

model Clinic {
  id                    String                 @id @default(cuid())
  name                  String
  slug                  String                 @unique
  legalName             String?
  timezone              String
  currency              String
  brandColor            String?
  businessType          String?
  publicName            String?
  publicDescription     String?
  websiteUrl            String?
  contactEmail          String?
  contactPhone          String?
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  members               ClinicMember[]
  doctors               Doctor[]
  services              Service[]
  patients              Patient[]
  appointments          Appointment[]
  tokens                AppointmentToken[]
  payments              Payment[]
  auditLogs             AuditLog[]
  whatsAppConversations WhatsAppConversation[]
  whatsAppMessages      WhatsAppMessage[]
  whatsAppBookingDrafts WhatsAppBookingDraft[]
  whatsAppCommandLogs   WhatsAppCommandLog[]
  doctorAvailabilities  DoctorAvailability[]
  doctorTimeOffs        DoctorTimeOff[]
  blockedTimes          ClinicBlockedTime[]
  notifications         NotificationOutbox[]
  waitlistEntries       WaitlistEntry[]
  waitlistOffers        WaitlistOffer[]

  @@index([isActive])
}

model ClinicMember {
  id        String   @id @default(cuid())
  userId    String
  clinicId  String
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([userId, clinicId])
  @@index([clinicId, role])
  @@index([clinicId, isActive])
}

model Doctor {
  id                    String                 @id @default(cuid())
  clinicId              String
  userId                String?
  name                  String
  specialty             String?
  bio                   String?
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  clinic                Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user                  User?                  @relation("DoctorLinkedUser", fields: [userId], references: [id], onDelete: SetNull)
  appointments          Appointment[]
  whatsAppBookingDrafts WhatsAppBookingDraft[]
  availabilityBlocks    DoctorAvailability[]
  timeOffs              DoctorTimeOff[]
  waitlistEntries       WaitlistEntry[]

  @@unique([clinicId, userId])
  @@index([clinicId, isActive])
  @@index([clinicId, name])
}

model Service {
  id                    String                 @id @default(cuid())
  clinicId              String
  name                  String
  description           String?
  durationMinutes       Int
  priceCents            Int?
  depositRequired       Boolean                @default(false)
  depositCents          Int?
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  clinic                Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments          Appointment[]
  whatsAppBookingDrafts WhatsAppBookingDraft[]
  waitlistEntries       WaitlistEntry[]

  @@unique([clinicId, name])
  @@index([clinicId, isActive])
}

model Patient {
  id                    String                 @id @default(cuid())
  clinicId              String
  name                  String
  phoneE164             String
  email                 String?
  notes                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  clinic                Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments          Appointment[]
  whatsAppConversations WhatsAppConversation[]
  notifications         NotificationOutbox[]
  waitlistEntries       WaitlistEntry[]

  @@unique([clinicId, phoneE164])
  @@index([clinicId, name])
}

model Appointment {
  id                    String                 @id @default(cuid())
  clinicId              String
  doctorId              String
  serviceId             String
  patientId             String
  startAt               DateTime
  endAt                 DateTime
  status                AppointmentStatus      @default(PENDING)
  source                AppointmentSource      @default(ADMIN)
  notes                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  clinic                Clinic                 @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor                Doctor                 @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  service               Service                @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  patient               Patient                @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tokens                AppointmentToken[]
  payments              Payment[]
  whatsAppBookingDrafts WhatsAppBookingDraft[]
  notifications         NotificationOutbox[]
  waitlistOffers        WaitlistOffer[]

  @@index([clinicId, startAt])
  @@index([clinicId, status, startAt])
  @@index([doctorId, startAt])
  @@index([patientId, startAt])
}

model AppointmentToken {
  id            String      @id @default(cuid())
  clinicId      String
  appointmentId String
  type          TokenType
  tokenHash     String      @unique
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime    @default(now())
  clinic        Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([clinicId, appointmentId])
  @@index([clinicId, expiresAt])
}

model Payment {
  id                String        @id @default(cuid())
  clinicId          String
  appointmentId     String
  amountCents       Int
  currency          String
  provider          String
  providerPaymentId String?
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  clinic            Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment       Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([clinicId, status, createdAt])
  @@index([appointmentId])
}

model NotificationOutbox {
  id            String              @id @default(cuid())
  clinicId      String
  appointmentId String?
  patientId     String?
  channel       NotificationChannel
  recipient     String
  templateKey   String
  subject       String?
  body          String
  payloadJson   Json?
  status        NotificationStatus  @default(PENDING)
  scheduledFor  DateTime?
  sentAt        DateTime?
  failedAt      DateTime?
  errorMessage  String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  clinic        Clinic              @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment   Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patient       Patient?            @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([clinicId, status, createdAt])
  @@index([clinicId, scheduledFor])
  @@index([appointmentId])
  @@index([patientId])
}

model WaitlistEntry {
  id                 String          @id @default(cuid())
  clinicId           String
  patientId          String
  serviceId          String
  doctorId           String?
  preferredDate      DateTime?
  preferredStartTime String?
  preferredEndTime   String?
  notes              String?
  autoAccept         Boolean         @default(false)
  status             WaitlistStatus  @default(ACTIVE)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  clinic             Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient            Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  service            Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  doctor             Doctor?         @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  offers             WaitlistOffer[]

  @@index([clinicId, status, createdAt])
  @@index([clinicId, serviceId, status, createdAt])
  @@index([clinicId, doctorId, status, createdAt])
  @@index([patientId, createdAt])
}

model WaitlistOffer {
  id             String              @id @default(cuid())
  clinicId       String
  waitlistEntryId String
  appointmentId  String?
  offeredStartAt DateTime
  offeredEndAt   DateTime
  status         WaitlistOfferStatus @default(PENDING)
  expiresAt      DateTime
  tokenHash      String              @unique
  consumedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  clinic         Clinic              @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  waitlistEntry  WaitlistEntry       @relation(fields: [waitlistEntryId], references: [id], onDelete: Cascade)
  appointment    Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([clinicId, status, expiresAt])
  @@index([waitlistEntryId, createdAt])
  @@index([appointmentId])
}

model AuditLog {
  id           String   @id @default(cuid())
  clinicId     String?
  userId       String?
  action       String
  entityType   String
  entityId     String?
  metadataJson Json?
  createdAt    DateTime @default(now())
  clinic       Clinic?  @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([clinicId, createdAt])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
}

model DoctorAvailability {
  id        String   @id @default(cuid())
  clinicId  String
  doctorId  String
  dayOfWeek Weekday
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, dayOfWeek, startTime, endTime])
  @@index([clinicId, doctorId, dayOfWeek, isActive])
  @@index([doctorId, dayOfWeek])
}

model DoctorTimeOff {
  id        String   @id @default(cuid())
  clinicId  String
  doctorId  String
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([clinicId, doctorId, startAt, endAt])
  @@index([doctorId, startAt])
}

model ClinicBlockedTime {
  id        String   @id @default(cuid())
  clinicId  String
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId, startAt, endAt])
}

model WhatsAppConversation {
  id            String                     @id @default(cuid())
  clinicId      String
  patientId     String?
  phoneE164     String
  status        WhatsAppConversationStatus @default(ACTIVE)
  currentIntent WhatsAppIntent?
  lastMessageAt DateTime                   @default(now())
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  clinic        Clinic                     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient       Patient?                   @relation(fields: [patientId], references: [id], onDelete: SetNull)
  messages      WhatsAppMessage[]
  bookingDrafts WhatsAppBookingDraft[]
  commandLogs   WhatsAppCommandLog[]

  @@unique([clinicId, phoneE164])
  @@index([clinicId, status, lastMessageAt])
}

model WhatsAppMessage {
  id             String                   @id @default(cuid())
  clinicId       String
  conversationId String
  direction      WhatsAppMessageDirection
  messageType    WhatsAppMessageType
  body           String?
  payloadJson    Json?
  status         WhatsAppMessageStatus    @default(RECEIVED)
  createdAt      DateTime                 @default(now())
  clinic         Clinic                   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  conversation   WhatsAppConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([clinicId, conversationId, createdAt])
}

model WhatsAppBookingDraft {
  id             String                     @id @default(cuid())
  clinicId       String
  conversationId String
  patientName    String?
  phoneE164      String
  serviceId      String?
  doctorId       String?
  preferredDate  DateTime?
  preferredTime  String?
  appointmentId  String?
  status         WhatsAppBookingDraftStatus @default(COLLECTING_SERVICE)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  clinic         Clinic                     @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  conversation   WhatsAppConversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  service        Service?                   @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  doctor         Doctor?                    @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  appointment    Appointment?               @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([clinicId, conversationId, status])
  @@index([clinicId, phoneE164, status])
}

model WhatsAppCommandLog {
  id             String                @id @default(cuid())
  clinicId       String
  userId         String?
  conversationId String?
  command        String
  parsedIntent   WhatsAppIntent?
  success        Boolean
  errorMessage   String?
  metadataJson   Json?
  createdAt      DateTime              @default(now())
  clinic         Clinic                @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user           User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  conversation   WhatsAppConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([clinicId, createdAt])
  @@index([conversationId, createdAt])
}
